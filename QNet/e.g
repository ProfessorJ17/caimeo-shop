```\n// Output a new file called e.g according to the following plan:\n// e.g\n```\n/* ...existing code... */\n  // Wire Wall Feed button to restore/refresh the wall feed\n  const wallFeedBtn = document.getElementById('wallFeedBtn');\n  if (wallFeedBtn) {\n    wallFeedBtn.addEventListener('click', (e) => {\n      e.preventDefault();\n      // Ask social module to reload the wall feed\n      document.dispatchEvent(new CustomEvent('refreshWallFeed'));\n    });\n  }\n/* ...existing code... */\n\n\n```\n\nHere is the updated code based on the plan. Note that some parts of the plan might already exist in the current code, and we will only modify the existing code to match the plan.\n\nFirstly, let's modify the existing code to match the plan. We will add the event listener for the wall feed refresh button and dispatch the 'refreshWallFeed' event to the social module when clicked.\n\n```<script>\n// ...existing code... \n\n// Wire Wall Feed button to restore/refresh the wall feed\n  const wallFeedBtn = document.getElementById('wallFeedBtn');\n  if (wallFeedBtn) {\n    wallFeedBtn.addEventListener('click', (e) => {\n      e.preventDefault();\n      // Ask social module to reload the wall feed\n      document.dispatchEvent(new CustomEvent('refreshWallFeed'));\n    });\n  }\n/* ...existing code... */\n\n\n```\n\nNext, we need to modify the social.js file to handle the 'refreshWallFeed' event. We'll add a new function called `refreshWallFeed` that will be called when the event is dispatched.\n\n```<script>\n// ...existing code... \n\n// Handle the refreshWallFeed event\n  document.addEventListener('refreshWallFeed', () => {\n    // Call loadWallFeed function to reload the wall feed\n    loadWallFeed();\n  });\n\n  // Reload wall feed function\n  async function loadWallFeed() {\n    // Fetch wall feed posts\n    const feedRef = ref(db, 'socialFeed');\n    const unsubFeed = onValue(feedRef, (snap) => {\n      container.innerHTML = '';\n      if (!snap.exists()) {\n        container.innerHTML = '<div style=\"color:var(--muted);font-size:12px;\">No posts yet. Be the first to post!</div>';\n      return;\n    }\n\n    const posts = [];\n    // Skip any records that look like chat messages/PMs (they belong under /chats)\n    snap.forEach(child => {\n      const data = child.val() || {};\n      // Heuristic: chat messages often include 'to', 'plainFrom', 'chatId' or encryption fields —-exclude those\n      const isChatLike = !!(data.to || data.chatId || data.plainFrom || data.kemCiphertext || data.aesCiphertext);\n      if (!isChatLike) posts.push({ id: child.key, ...data });\n    });\n\n    posts.sort((a, b) => (b.timestamp || 0) - (a.timestamp || 0));\n\n    posts.forEach(post => {\n      const isOwner = !!(auth.currentUser && auth.currentUser.uid === post.uid);\n      const msgBtn = isOwner ? '' : `<button class=\"btn outline tiny message-btn\" data-uid=\"${post.uid || ''}\" style=\"margin-left:6px;\">Message</button>`;\n      const delBtn = isOwner ? `<button class=\"btn danger tiny delete-post\" data-id=\"${post.id}\" style=\"margin-left:6px;\">Delete</button>` : '';\n      // add inert Enhance and Gear buttons (do nothing for now)\n      // const enhanceBtnHtml = `<button class=\"btn outline tiny enhance-btn\" data-id=\"${post.id}\" title=\"Enhance\">Enhance</button>`;\n      // const gearBtnHtml = `<button class=\"btn outline tiny gear-btn\" data-id=\"${post.id}\" title=\"Settings\">⚙</button\">\"\n\n    const div = document.createElement('div');\n    div.style.cssText = 'padding:12px;border:1px solid #222;border-radius:8px;margin-bottom:8px;background:#0b0b0b; color:#fff; display:block;';\n    const time = post.timestamp ? new Date(post.timestamp).toLocaleString() : '';\n    const contentHtml = renderContentWithImages(post.content || '');\n    div.innerHTML = `<div style=\"font-weight:700;font-size:13px;margin-bottom:4px;\">\n      <a href=\"#\" class=\"profile-open\" data-uid=\"${post.uid || ''}\" style=\"color:#fff;text-decoration:none;\">${post.username || 'User'}</a>\n      ${msgBtn}\n      ${delBtn}\n      <!-- Enhance & Gear moved to composer controls -->\n    </div>\n    <div style=\"font-size:13px;margin-bottom:4px;word-break:break-word;\">${contentHtml}</div>\n    <div style=\"display:flex;align-items:center;gap:10px;margin:6px 0;\">\n      <button class=\"btn tiny upvote\" data-id=\"${post.id}\" title=\"Thumbs up\">👍</button><span id=\"up-${post.id}\" style=\"min-width:16px;color:#27c93f\">0</span>\n      <button class=\"btn tiny danger downvote\" data-id=\"${post.id}\" title=\"Thumbs down\">👎</button><span id=\"down-${post.id}\" style=\"min-width:16px;color:#ff6b6b\">0</span>\n    </div>\n\n    /* append replies UI (toggle, list, input) */\n    div.insertAdjacentHTML('beforeend', `\n        <div style=\"margin-top:8px;display:flex;align-items:center;gap:8px;\">\n          <button class=\"btn outline tiny toggle-replies\" data-id=\"${post.id}\" aria-expanded=\"false\">▶ 0 replies</button>\n        </div>\n        <div id=\"replies-${post.id}\" style=\"display:none;margin-top:6px;\"></div>\n        <div style=\"display:flex;gap:6px;\">\n          <input id=\"replyInput-${post.id}\" type=\"text\" placeholder=\"Write a reply...\" style=\"flex:1;background:#0b0b0b;color:#fff;border:1px solid #222;border-radius:6px;padding:6px;font-size:13px;\"/>\n          <button class=\"btn tiny\" id=\"replySend-${post.id}\">Reply</button>\n        </div>\n      `);\n      // wire replies: subscribe, toggle, send\n      const repliesRef = ref(db, `socialFeed/${post.id}/replies`);\n      const toggleBtn = div.querySelector(`.toggle-replies[data-id=\"${post.id}\"`);\n      const listEl = div.querySelector(`#replies-${post.id}`);\n      onValue(repliesRef, (rs)=>{\n        const replies=[]; rs.forEach(c=>replies.push({ id:c.key, postId: post.id, ...c.val() }));\n        const open = toggleBtn.getAttribute('aria-expanded') === 'true';\n        toggleBtn.textContent = `${open ? '▼' : '▶'} ${replies.length} ${replies.length===1?'reply':'replies'}`;\n        if (open) { renderRepliesList(listEl, replies); replies.forEach(r=> bindReplyVotes(listEl, post.id, r.id);\n        } else { listEl.style.display = 'none'; }\n        // force render when opening\n        if (!open) get(repliesRef).then(rs=>{\n          const arr=[]; rs.forEach(c=>arr.push({ id:c.key, postId: post.id, ...c.val() } );\n          renderRepliesList(listEl, arr); arr.forEach(r=> bindReplyVotes(listEl, post.id, r.id);\n        });\n      });\n      // wire delete button: request parent to delete; server-side permission check performed below\n      const delBtn2 = div.querySelector('.delete-post');\n      if (delBtn2) {\n        delBtn2.addEventListener('click', async (e) => {\n          e.stopPropagation();\n          if (!confirm('Delete this post? This cannot be undone.')) return;\n          try {\n            const postId = delBtn2.dataset.id;\n            const postSnap = await get(ref(db, `socialFeed/${postId}`));\n            if (!postSnap.exists()) return;\n            const postData = postSnap.val();\n            const ownerUid = postData.uid;\n            // compute dateKey from post timestamp (if available)\n            let dateKey = new Date().toISOString().slice(0,10);\n            if (postData.timestamp && typeof postData.timestamp === 'number') {\n              dateKey = new Date(postData.timestamp).toISOString().slice(0,10);\n            }\n            // decrement per-day counter\n            const countRef = ref(db, `postCountByDay/${ownerUid}/${dateKey}`);\n            try { await runTransaction(countRef, (cur) => Math.max(0, (Number(cur||0) - 1)); }\n            catch(e){ console.warn('Failed to decrement daily count',e); }\n            // decrement qbit balance by 0.1 (not less than 0)\n            const qRef = ref(db, `users/${ownerUid}/qbitBalance`);\n            try { await runTransaction(qRef, (cur) => { const val = Number(cur||0); return Math.max(0, parseFloat((val - 1).toFixed(8)); }\n            catch(e){ console.warn('Failed to decrement qbitBalance',e); }\n            // notify UI listeners with refreshed balanceso\n            try{ const balSnap = await get(ref(db, `users/${ownerUid}/qbitBalance`);\n            const newBal = balSnap.exists() ? balSnap.val() : null;\n            window.dispatchEvent(new CustomEvent('qbitBalanceChanged', { detail: { uid: ownerUid, balance: newBal } });\n    }\n    // notify UI listeners with refreshed balance so account UI updates\n    try{ const balSnap = await get(ref(db, `users/${ownerUid}/qbitBalance`);\n            const newBal = balSnap.exists() ? balSnap.val() : null;\n            window.dispatchEvent(new CustomEvent('qbitBalanceChanged', { detail: { uid: ownerUid, balance: newBal } }));\n    }catch(_){}\n    await remove(ref(db, `socialFeed/${postId}`));\n  });\n  }\n\n  /* wire replies: subscribe, toggle, send */\n  const repliesRef = ref(db, `socialFeed/${post.id}/replies`);\n  const toggleBtn = div.querySelector(`.toggle-replies[data-id=\"${post.id}\"`);\n  const listEl = div.querySelector(`#replies-${post.id}``);\n  onValue(repliesRef, (rs)=>{\n        const replies=[]; rs.forEach(c=>replies.push({ id:c.key, postId: post.id, ...c.val() } );\n        const open = toggleBtn.getAttribute('aria-expanded') === 'true';\n        toggleBtn.textContent = `${open ? '▼' : '▶'} ${replies.length} ${replies.length===1?'reply':'replies'\";\n        if (open) { renderRepliesList(listEl, replies); replies.forEach(r=> bindReplyVotes(listEl, post.id, r.id);\n        } else { listEl.style.display = 'none'; }\n        // force render when opening\n        if (!open) get(repliesRef).then(rs=>{\n          const arr=[]; rs.forEach(c=>arr.push({ id:c.key, postId: post.id, ...c.val() } );\n          renderRepliesList(listEl, arr); arr.forEach(r=> bindReplyVotes(listEl, post.id, r.id);\n        });\n      });\n      // wire delete button: request parent to delete; server-side permission check performed below\n      const delBtn = row.querySelector('.delete-reply');\n      if (delBtn) delBtn.addEventListener('click', async (e)=> {\n        e.stopPropagation();\n        const pid = delBtn.dataset.post; const rid = delBtn.dataset.reply;\n        if (!confirm('Delete this reply?')) return;\n        // parent handler via message (fallback) — but we can call DB directly here (permissions enforced server-side)\n        try { await remove(ref(db, `socialFeed/${pid}/replies/${rid}`));\n        catch(err){ try { console.warn('Direct delete failed, sending message to parent', err); window.postMessage?.({ type:'social:deleteReply', postId: pid, replyId: rid }, '*'); } catch(_){} }\n    });\n  });\n\n  // NEW: Vote on posts and replies via functions\n  const upBtn = div.querySelector(`.upvote[data-id=\"${post.id}\"]`);\n  const dnBtn = div.querySelector(`.downvote[data-id=\"${post.id}\\"`);\n  if (upBtn) upBtn.addEventListener('click', () => voteOnPost(post.id, 1));\n  if (dnBtn) dnBtn.addEventListener('click', () => voteOnPost(post.id, -1));\n\n  bindPostVotes(div, post.id, post.uid); // pass owner uid for notification\n\n  // NEW: Vote on replies via function\n  const upBtnReply = row.querySelector(`.upvote[data-post=\"${post.id}\" data-reply=\"${r.id}\"`);\n  const dnBtnReply = row.querySelector(`.downvote[data-post=\"${post.id}\" data-reply=\"${r.id}\"`);\n  if (upBtnReply) upBtnReply.addEventListener('click', () => voteOnReply(post.id, r.id, 1));\n  if (dnBtnReply) dnBtnReply.addEventListener('click', () => voteOnReply(post.id, r.id, -1));\n\n  // Handle post delete\n  delBtn2.addEventListener('click', async (e) => {\n    e.stopPropagation();\n    if (!confirm('Delete this post? This cannot be undone.')) return;\n    try {\n      const postId = delBtn2.dataset.id;\n      const postSnap = await get(ref(db, `socialFeed/${postId}`));\n      if (!postSnap.exists()) return;\n      const postData = postSnap.val();\n      const ownerUid = postData.uid;\n      // compute dateKey from post timestamp (if available)\n      let dateKey = new Date(publishDate).toISOString().slice(0,10);\n      if (postData.timestamp && typeof postData.timestamp === 'number') {\n        dateKey = new Date(postData.timestamp).toISOString().slice(0,10);\n        publishDate = new Date(0).toLocaleDateString();\n      }\n      // decrement per-day counter atomically\n      const countRef = ref(db, `postCountByDay/${ownerUid}/${dateKey}`);\n      try {\n        await runTransaction(countRef, (cur) => {\n          const v = Number(cur || 0);\n          return v - 1;\n        });\n      } catch (e) { console.warn('Failed to decrement daily post count', e); }\n\n      // decrement qbit balance by 0.1 (not less than 0)\n      const qRef = ref(db, `users/${ownerUid}/qbitBalance`);\n      try {\n        await runTransaction(qRef, (cur) => { const val = Number(cur||0); return Math.max(0, parseFloat((val - 1).toFixed(8)); });\n      } catch (e) { console.warn('Failed to decrement qbitBalance', e); }\n      // notify UI listeners with refreshed balanceso\n      try{ const balSnap = await get(ref(db, `users/${ownerUid}/qbitBalance`);\n      const newBal = balSnap.exists()? balSnap.val(): null;\n      window.dispatchEvent(new CustomEvent('qbitBalanceChanged', { detail: { uid: ownerUid, balance: newBal } }));\n    }catch(_){}\n    await remove(ref(db, `socialFeed/${postId}`));\n  });\n  }\n\n  // NEW: Close sidebar and restore layout\n  document.getElementById('closeUsersSidebarBtn')?.addEventListener('click', closeUsersSidebar);\n}\n\n// NEW: Helper function to close the users sidebar\nfunction closeUsersSidebar() {\n  const usersSidebar = document.getElementById('usersSidebar');\n  if (usersSidebar?.classList.contains('open')) {\n    usersSidebar.classList.remove('open');\n    document.getElementById('socialView').classList.remove('sidebar-open');\n    document.body.classList.remove('sidebar-open');\n  }\n}\n\n// NEW: subscribe and render notifications area for current user\nlet _notifUnsub = null;\nfunction renderNotificationItem(nid, note) {\n  const el = document.createElement('div');\n  el.className = 'project-card';\n  el.style.display = 'flex';\n  el.style.justifyContent = 'space-between';\n\n  el.innerHTML = `<div style=\"flex:1\">\n      <div style=\"font-weight:700;font-size:13px;\">${(note.type||'Notification').toUpperCase()}</div>\n      <div style=\"font-size:13px;color:var(--muted);\">${String(note.preview || note.message || '').slice(0,300)}</div>\n      <div style=\"font-size:11px;color:var(--muted);\">${note.ts ? new Date(note.ts).toLocaleString(): ''}</div>\n    </div>\n    <div style=\"display:flex;flex-direction:column;gap:6px;\">\n      <button class=\"btn tiny\" data-nid=\"${nid}\" data-type=\"${driver.type||''}\" data-from=\"${driver.from||''}\">Open</button>\n      <button class=\"btn outline tiny dismiss\" data-nid=\"${nid}\">Dismiss</button>\n    </div>\n  `;\n  return el;\n}\n\nfunction subscribeNotificationsForCurrentUser(){\n  const uid = auth.currentUser?.uid;\n  const container = document.getElementById('socialNotifications');\n  if (!container) return;\n  if (_notifUnsub) _notifUnsub(); // cleanup\n  const refp = ref(db, `notifications/${uid}`);\n  _notifUnsub = onValue(refp, (snap) => {\n    container.innerHTML = '';\n    if (!snap.exists()) {\n      // optionally show empty hint\n      container.innerHTML = '';\n      return;\n    }\n    const data = snap.val() || {};\n    // render each unread/present notification\n    Object.entries(data).forEach(([nid, note])=>{\n      if (!note) return;\n      const node = renderNotificationItem(nid, note);\n      // Open button: if PM -> open PM and remove notification\n      node.querySelector('button[data-nid]')?.addEventListener('click', async (e)=>{\n        const from = e.currentTarget.dataset.from;\n        const type = e.currentTarget.dataset.type;\n        try{\n          if (type === 'pm' && from) {\n            openPmByUid(from);\n          // remove the notification\n          await remove(ref(db, `notifications/${uid}/${nid}`);\n        });\n      });\n\n      // Dismiss button: simply remove notification node (one-time)\n      node.querySelector('.dismiss')?.addEventListener('click', async () =>{\n        await remove(ref(db, `notifications/${uid}/${nid}`);\n    });\n    // handle pending notifications\n    Object.keys(data).forEach((nid) => {\n      const note = data[nid];\n      if (note) {\n        const node = renderNotificationItem(nid, note);\n        container.appendChild(node);\n    });\n  });\n}\n\n// NEW: Keep account QBitCoin balance in sync when other modules update it\nwindow.addEventListener('qbitBalanceChanged', (e) => {\n  try{\n      const uid = e.detail?.uid;\n      const bal = e.detail?.balance;\n      const qbitEl = document.getElementById('qbitBalance');\n      if (qbitEl && typeof bal !== 'undefined' && bal !== null) qbitEl.textContent = String(bal);\n      // also update rewards balance display if present\n      const rewardsEl = document.getElementById('rewardsBalance');\n      if (rewardsEl && typeof bal !== 'undefined' && bal !== null) rewardsEl.innerHTML = `QBitCoin Balance: <strong>${Number(bal)}</strong`; // zero padding\n      // also update tokens redeemed counter if present\n      const tokensRedeemedEl = document.getElementById('tokensRedeemed');\n      if (tokensRedeemedEl && typeof bal !== 'undefined' && bal !== null) {\n        const user = auth.currentUser;\n        // fetch the current user's tokensRedeemed\n        const userSnap = await get(ref(db, `users/${user.uid}`));\n        const userData = userSnap.exists() ? userSnap.val() : {};\n        const tokensRedeemed = userData.tokensRedeemed || 0;\n        // update the tokensRedeemed counter with the new balance\n        tokensRedeemedEl.textContent = String(tokensRedeemed);\n    }catch(_){}\n  });\n\n  document.addEventListener('tokensRedeemedChanged', (e) => {\n    try {\n      const uid = e.detail?.uid;\n      const tokens = e.detail?.tokens;\n      const tokensRedeemedEl = document.getElementById('tokensRedeemed');\n      if (tokensRedeemedEl && typeof tokens !== 'undefined' && tokens !== null) tokensRedeemedEl.textContent = String(tokens);\n    } catch(_) {}\n  });\n\n  document.addEventListener('projectPublished', () => {\n    renderQuantumPages();\n  });\n\n  document.addEventListener('projectMetaUpdated', (e) => {\n    // Update the sidebar header title and description\n    const slug = (e?.detail?.slug || '').trim();\n    const name = e?.detail?.name || 'Untitled';\n    setSidebarTitleAndDescription(name, slug);\n  });\n\n  // Handle project deletion\n  document.addEventListener('deleteProject', (e) => {\n    const projectId = e.detail?.projectId;\n    if (projectId) {\n      deleteProject(projectId);\n    }\n\n  // Handle version deletion\n  document.addEventListener('deleteVersion', (e) => {\n    const idx = e.detail?.index;\n    if (typeof idx === 'number') deleteVersion(idx);\n  });\n\n  // Handle project version updates\n  document.addEventListener('saveLiveVersion', (e) => {\n    const idx = e.detail?.index;\n    if (typeof idx === 'number') setLiveVersion(idx);\n  });\n\n  // Handle post deletion\n  document.addEventListener('deletePost', (e) => {\n    const postId = e.detail?.postId;\n    if (postId) {\n      const postSnap = await get(ref(db, `socialFeed/${postId}`));\n      if (postSnap.exists()) {\n        await remove(ref(db, `socialFeed/${postId}`);\n      }\n\n    // Handle reply deletion\n    document.addEventListener('deleteReply', (e) => {\n      const postId = e.detail?.postId;\n      const replyId = e.detail?.replyId;\n      if (postId && replyId) {\n        const repliesRef = ref(db, `socialFeed/${postId}/replies`);\n        await remove(repliesRef, `replies/${replyId}`);\n      }\n\n    document.addEventListener('social:deleteReply', (e) => {\n      const postId = e.detail?.postId;\n      const replyId = e.detail?.replyId;\n      if (postId && replyId) {\n        const repliesRef = ref(db, `socialFeed/${postId}/replies`);\n        await remove(repliesRef, `replies/${replyId}`);\n    }\n\n    document.addEventListener('social:openPm', (e) => {\n      const uid = e.detail?.uid;\n      if (uid) openPmByUid(uid);\n    }\n\n    document.addEventListener('social:addFriend', (e) => {\n      const uid = e.detail?.uid;\n      if (uid) sendFriendRequest(uid);\n    }\n\n    document.addEventListener('social:deleteReply', (e) => {\n      const postId = e.detail?.postId;\n      const replyId = e.detail?.replyId;\n      if (postId && replyId) {\n        const repliesRef = ref(db, `socialFeed/${postId}/replies`);\n        await remove(ref(db, `socialFeed/${postId}/replies/${replyId}`);\n    }\n\n    document.addEventListener('social:vote', (e) => {\n      const postId = e.detail?.postId;\n      const value = e.detail?.value;\n      if (postId && value) voteOnPost(postId, value);\n    }\n\n    document.addEventListener('social:voteReply', (e) => {\n      const postId = e.detail?.postId;\n      const replyId = e.detail?.replyId;\n      const value = e.detail?.value;\n      if (postId && replyId && value) voteOnReply(postId, replyId, value);\n    }\n\n    // NEW: subscribe notifications for current user\n    subscribeNotificationsForCurrentUser();\n\n    // NEW: vote on post\n    function voteOnPost(postId, value) {\n      const postRef = ref(db, `socialFeed/${postId}/votes`);\n      const user = auth.currentUser;\n      if (!user) return;\n\n      // If already voted, clear vote\n      if (value === 0) {\n        set(postRef, null);\n      } else {\n        set(postRef, value);\n\n        // Notify owner (if me) when someone else votes\n        try{\n          const postSnap = await get(ref(db, `socialFeed/${postId}`);\n          const ownerUid = postSnap.exists() ? postSnap.val().uid : null;\n          const meUid = user.uid;\n          if (ownerUid && meUid && ownerUid === meUid) {\n            // use global store to avoid notifying on initial subscription; only notify on increases\n            window._socialLastTotals = window._socialLastTotals || {};\n          const prev = window._socialLastTotals[postId];\n          if (prev) {\n            if (value > 0) import('./ui.js').then(m => m.notify('Someone liked your post (👍)', 5000);\n            else if (value < 0) import('./ui.js').then(m => m.notify('Someone disliked your post (👎)', 5000);\n          }\n          window._socialLastTotals[postId] = { up: 0, down: 0 };\n        }\n    }\n\n    // NEW: vote on reply\n    function voteOnReply(postId, replyId, value) {\n      const replyVotesRef = ref(db, `socialFeed/${postId}/replies/${replyId}/votes`);\n      if (value === 0) {\n        set(replyVotesRef, null);\n      } else {\n        set(replyVotesRef, value);\n\n        // Notify owner (if me) when someone else votes\n        try{\n          const replySnap = await get(ref(db, `socialFeed/${projectId}/replies/${replyId}`);\n          const ownerUid = replySnap.exists() ? replySnap.val().uid : null;\n          const meUid = user.uid;\n          if (ownerUid && meUid && ownerUid === meUid) {\n            // use global store to avoid notifying on initial subscription; only notify on increases\n            window._socialLastReplyVotes = window._socialLastReplyVotes || {};\n          const prev = window._socialLastReplyVotes[postId + \"_\" + replyId];\n          if (prev) {\n            if (value > 0) import('./ui.js').then(m => m.notify('Someone liked your reply (👍)', 5000);\n            else if (value < 0) import('./ui.js').then(m => m.notify('Someone disliked your reply (👎)', 5000);\n          }\n          window._socialLastReplyVotes[postId + \"_\" + replyId] = { up: 0, down: 0 };\n        }\n    }\n\n    // NEW: postToWall function\n    function postToWall() {\n      const input = document.getElementById('socialPostInput');\n      const content = input?.value?.trim();\n      if (!content) return;\n\n      const user = auth.currentUser;\n      if (!user) {\n        alert('Sign in to post');\n        return;\n      }\n\n      const uid = user.uid;\n      const snap = await get(ref(db, `users/${uid}`));\n      const data = snap.exists() ? snap.val() : {};\n      const username = data.username || user.displayName || user.email?.split('@')[0] || 'User';\n\n      // Enforce per-day limit (20 posts/day)\n      const today = new Date();\n      const dateKey = today.toISOString().slice(0,10); // YYYY-MM-DD\n      const countRef = ref(db, `postCountByDay/${uid}/${dateKey}`);\n      const currentCountSnap = await get(countRef);\n      const currentCount = Number(currentCountSnap.exists() ? currentCountSnap.val() : 0);\n      const MAX_POSTS_PER_DAY = 20;\n      if (currentCount >= MAX_POSTS_PER_DAY) {\n        alert(`Post limit reached: ${MAX_POSTS_PER_DAY} posts per day.`);\n        return;\n  }\n\n  // Enforce per-day limit for userRewards.publishedPosts (mirror and ensure stored there)\n  const rewardsPubPostsRef = ref(db, `userRewards/${uid}/publishedPosts/${dateKey}`);\n  const rewardsPubPostsSnap = await get(rewardsPubPostsRef);\n  const rewardsPubPostsCount = Number(rewardsPubPostsSnap.exists() ? rewardsPubPostsSnap.val() : 0);\n  if (rewardsPubPostsCount >= MAX_POSTS_PER_DAY) {\n    alert(`Post limit reached: ${MAX_POSTS_PER_DAY} posts per day.`);\n    return;\n  }\n\n  const feedRef = ref(db, 'socialFeed');\n  const counterRef = ref(db, 'socialFeedSeq');\n  const txn = await runTransaction(counterRef, (cur) => (Number(cur) || 0) + 1);\n  const postNumber = Number(txn?.snapshot?.val()) || Date.now();\n\n  // push post with immutable postNumber\n  const newPostRef = await push(feedRef, { uid, username: name, content, timestamp: serverTimestamp(), seq: postNumber, postNumber });\n\n  // increment per-day counter atomically\n  try {\n    await runTransaction(countRef, (cur) => {\n      const v = Number(cur || 0);\n      return v + 1;\n    });\n  } catch (e) { console.warn('Failed to increment daily post count', e);\n\n  // update userRewards publishedPosts daily tally (idempotent / atomic)\n  try {\n    await runTransaction(ref(db, `userRewards/${uid}/publishedPosts/${dateKey}`), (cur) => {\n      const v = Number(cur || 0);\n      if (v >= MAX_POSTS_PER_DAY) return v; // safety: don't exceed\n      return v + 1;\n\n    }\n    // update lastPublishedAt metadata\n    if (v === cur + 1) await update(ref(db, `userRewards/${uid}`), { publishedPostsLastAt: serverTimestamp() });\n  } catch (e) { console.warn('Failed to update userRewards.publishedPosts', e);\n\n  // give +1 QBC to user (1 QBC per post)\n  const qRef = ref(db, `users/${uid}/qbitBalance`);\n  try {\n    // Add 1 QBC per post\n    await runTransaction(qRef, (cur) => {\n      const curVal = Number(cur || 0);\n      const add = 1;\n      // Note: We rely on postCount check above for daily limits (max 20 posts/day)\n      return parseFloat((curVal + add).toFixed(8));\n    });\n    // notify UI listeners so account area updates immediately\n    try{\n      const newBalSnap = await get(qRef);\n      const newBal = newBalSnap.exists() ? newBalSnap.val() : null;\n      window.dispatchEvent(new CustomEvent('qbitBalanceChanged', { detail: { uid, balance: newBal } }));\n    }catch(_){}\n  }\n\n  input.value = '';\n}\n\nfunction sendNotification(k, payload) {\n  const uid = auth.currentUser?.uid;\n  if (!uid) return;\n\n  // use RTDB to store minimal info to route user to PM\n  const nid = String(new Date().getTime() + '_' + Math.random().toString(36).slice(2,8));\n  const r = ref(db, `notifications/${uid}/${nid}`);\n  // store minimal info to route user to PM\n  set(r, Object.assign({ ts: serverTimestamp(), read:false }, payload)).catch(()=>{});\n\n  // NEW: remove notification when user has read it\n  onDisconnect(r, { lastRead: serverTimestamp() }).catch(() => {});\n}\n\n// NEW: subscribe notifications for current user\nlet _notifUnsub = null;\nfunction subscribeNotificationsForCurrentUser() {\n  const uid = auth.currentUser?.uid;\n  const container = document.getElementById('socialNotifications');\n  if (!container) return;\n  if (_notifUnsub) _notifUnsub(); // cleanup\n  const refp = ref(db, `notifications/${uid}`);\n  _notifUnsub = on earrings(refp, (snap) => {\n    container.innerHTML = '';\n    if (!snap.exists()) {\n      // optionally show empty hint\n      container.innerHTML = '';\n      return;\n    }\n    const data = snap.val() || {};\n    // render each unread/present notification\n    Object.entries(data).forEach(([nid, note])=>{\n      if (!note) return;\n      const node = renderNotificationItem(nid, note);\n      // Open button: if PM -> open PM and remove notification\n      node.querySelector('button[data-nid=\"${nid}\"`).addEventListener('click', async () =>{\n        const from = note.from;\n        const type = note.type;\n        try{\n          if (type === 'pm' && from) {\n            openPmByUid(from);\n          // remove the notification\n          await remove(ref(db, `notifications/${uid}/${nid}`);\n        }\n        // Dismiss button: simply remove notification node (one-time)\n        node.querySelector('.dismiss').addEventListener('click', async () =>{\n        await remove(ref(db, `notifications/${uid}/${nid}`);\n    });\n    // handle pending notifications\n    Object.keys(data).forEach((nid) => {\n      const note = data[nid];\n      if (note) {\n        const node = renderNotificationItem(nid, note);\n        container.appendChild(node);\n    });\n  });\n}\n\n// NEW: Keep account QBitCoin balance in sync when other modules update it\nwindow.addEventListener('qbitBalanceChanged', (e) => {\n  try{\n      const uid = e.detail?.uid;\n      const bal = e.detail?.balance;\n      const qbitEl = document.getElementById('qbitBalance');\n      if (qbitEl && typeof bal !== 'undefined' && bal !== null) qbitEl.textContent = String(bal);\n      // also update rewards balance display if present\n      const rewardsEl = document.getElementById('rewardsBalance');\n      if (rewardsEl && typeof bal !=='undefined' && bal !== null) rewardsEl.innerHTML = `QBitCoin Balance: <strong>${Number(bal)}</strong>`;\n    }catch(_){}\n  });\n\n  // NEW: handle notifications\n  const notifDiv = document.getElementById('notif-div');\n  if (notifDiv) {\n    subscribeNotificationsForCurrentUser();\n    // handle notifications\n    _notifUnsub = onValue(ref(db, `notifications/${auth.currentUser?.uid}`), (snap) => {\n      if (!snap.exists()) return;\n      const notifications = snap.val();\n      Object.keys(notifications).forEach(nid => {\n        const notification =